  m_Script: {fileID: 11500000, guid: 5e3748c50dd45bb4284b9398008214da, type: 3}
  m_Name: 07_Sirup Ekspektoran
  m_EditorClassIdentifier: 
  medicineTitle: Sirup Ekspektoran
  medicineCategory: BATUK
  medicineIcon: {fileID: 21300000, guid: e6097cd5ed154744ebb58c6603d74540, type: 3}
  medicineDescription: Obat pengencer dahak yang bekerja memecah struktur mukus di
    saluran napas, mempermudah pengeluaran lendir, serta memperbaiki ventilasi udara
    pada pasien batuk berdahak.
  baseDoseFormula: (WBC/1000)+(RR x 1.5)+(Temp x 2)-85
  logicRules:
  - paramIcon: {fileID: 21300000, guid: 4c429e5beb3e14a47ae18376c4974b95, type: 3}
    conditionText: "WBC \u2265 11K & SpO2 < 95"
    resultFormula: Base x 1.4) + (VAS x 0.6)
  - paramIcon: {fileID: 21300000, guid: 4c429e5beb3e14a47ae18376c4974b95, type: 3}
    conditionText: "WBC \u2265 11K & SpO2 \u2265 95"
    resultFormula: (Base x 1.2) + 4.5
  - paramIcon: {fileID: 21300000, guid: 4c429e5beb3e14a47ae18376c4974b95, type: 3}
    conditionText: WBC < 11K & RR > 20
    resultFormula: Base + (BMI / 10)
  defaultRuleLabel: ELSE USE DEFAULT DOSE
