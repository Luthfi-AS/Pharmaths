MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5e3748c50dd45bb4284b9398008214da, type: 3}
  m_Name: 08_Ibuprofen
  m_EditorClassIdentifier: 
  medicineTitle: Ibuprofen
  medicineCategory: INFLAMASI
  medicineIcon: {fileID: 21300000, guid: 6fb4c96a44209854cb29768dc8b6a912, type: 3}
  medicineDescription: Obat antiinflamasi nonsteroid untuk meredakan nyeri otot dan
    peradangan dengan menghambat enzim penyebab rasa sakit serta pembengkakan pada
    jaringan lunak tubuh.
  baseDoseFormula: (VAS x 5) + (BMI x 0.7) + (SBP / 25)
  logicRules:
  - paramIcon: {fileID: 21300000, guid: d6d8dc4587e4a5d4d857954030708ae7, type: 3}
    conditionText: "VAS = 8 & BMI \u2265 28"
    resultFormula: (Base x 1.5) + (BMI x 0.3)
  - paramIcon: {fileID: 21300000, guid: d6d8dc4587e4a5d4d857954030708ae7, type: 3}
    conditionText: VAS = 8 & BMI < 28
    resultFormula: (Base x 1.25) + 3.5
  - paramIcon: {fileID: 21300000, guid: d6d8dc4587e4a5d4d857954030708ae7, type: 3}
    conditionText: VAS < 8 & SBP > 130
    resultFormula: Base + (VAS x 0.8)
  defaultRuleLabel: ELSE USE DEFAULT DOSE
