  m_Script: {fileID: 11500000, guid: 5e3748c50dd45bb4284b9398008214da, type: 3}
  m_Name: 03_Salbutamol
  m_EditorClassIdentifier: 
  medicineTitle: Salbutamol
  medicineCategory: ASMA/SESAK
  medicineIcon: {fileID: 21300000, guid: 16f3bffc64397e64ba6e33b26cc89be7, type: 3}
  medicineDescription: Bronkodilator untuk merelaksasi otot saluran napas, memulihkan
    saturasi oksigen, serta meredakan sesak napas akut akibat penyempitan bronkus
    secara cepat dan efektif.
  baseDoseFormula: ((100-SpO2) x 2.5) + (RR x 0.8) + (BMI/5)
  logicRules:
  - paramIcon: {fileID: 21300000, guid: e83a98d714ba2534a8569ac8de2477f1, type: 3}
    conditionText: SpO2 < 90 & RR > 28
    resultFormula: (Base x 1.5) + (HR x 0.1)
  - paramIcon: {fileID: 21300000, guid: e83a98d714ba2534a8569ac8de2477f1, type: 3}
    conditionText: "SpO2 < 90 & RR \u2264 28"
    resultFormula: (Base x 1.3) + 5.0
  - paramIcon: {fileID: 21300000, guid: e83a98d714ba2534a8569ac8de2477f1, type: 3}
    conditionText: "SpO2 \u2265 90 & HR > 120"
    resultFormula: Base + (VAS x 1.2)
  defaultRuleLabel: ELSE USE DEFAULT DOSE
