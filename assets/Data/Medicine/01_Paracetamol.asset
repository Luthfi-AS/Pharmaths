  m_Script: {fileID: 11500000, guid: 5e3748c50dd45bb4284b9398008214da, type: 3}
  m_Name: 01_Paracetamol
  m_EditorClassIdentifier: 
  medicineTitle: Paracetamol
  medicineCategory: DEMAM
  medicineIcon: {fileID: 21300000, guid: 24466fae83524044abe2073899ff21cc, type: 3}
  medicineDescription: Obat penurun panas (antipiretik) dan pereda nyeri (analgesik)
    ringan hingga sedang. Digunakan untuk meredakan gejala seperti demam, sakit kepala,
    sakit gigi, atau nyeri otot.
  baseDoseFormula: (BMI x 1.5) + (Temp x 2) - 65
  logicRules:
  - paramIcon: {fileID: 21300000, guid: 6dbb3918da3552447bdab6464143e365, type: 3}
    conditionText: "Temp \u2265 38.5 & VAS = 4"
    resultFormula: (Base x 1.3) + 2.5
  - paramIcon: {fileID: 21300000, guid: 6dbb3918da3552447bdab6464143e365, type: 3}
    conditionText: "Temp \u2265 38.5 & VAS < 4"
    resultFormula: Base + (HR x 0.15)
  - paramIcon: {fileID: 21300000, guid: 6dbb3918da3552447bdab6464143e365, type: 3}
    conditionText: "Temp < 38.5 & BMI \u2264 20 "
    resultFormula: Base x 0.85
  defaultRuleLabel: ELSE USE DEFAULT DOSE
